{
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "crons": [
    { "path": "/api/cron/ticket-emails", "schedule": "0 13 * * *" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
